---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date) {
  return d.toISOString().slice(0, 10);
}
---
<Base title={`${post.data.title} — SettLabs Blog`} description={post.data.description}>
<style>
  .wrap { max-width: 720px; margin: 0 auto; padding: 24px 16px; }
  .back { font-size: 0.8rem; color: #6a8090; text-decoration: none; display: inline-block; margin-bottom: 24px; }
  .back:hover { color: #00c8f0; text-decoration: none; }
  .post-date { font-size: 0.7rem; color: #4a6070; margin-bottom: 8px; }
  h1 { font-size: 1.5rem; color: #00c8f0; letter-spacing: 1px; margin-bottom: 8px; }
  .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 28px; }
  .tag { font-size: 0.65rem; color: #4a6070; background: #0a0f18; border: 1px solid #1a2a3a; border-radius: 3px; padding: 1px 6px; }
  .content { font-size: 0.875rem; color: #8aa0b0; line-height: 1.85; }
  .content h2 { font-size: 1rem; color: #00c8f0; margin-top: 28px; margin-bottom: 10px; border-bottom: 1px solid #1a2a3a; padding-bottom: 4px; }
  .content h3 { font-size: 0.9rem; color: #b8ccd8; margin-top: 20px; margin-bottom: 8px; }
  .content p { margin-bottom: 12px; }
  .content ul, .content ol { padding-left: 20px; margin-bottom: 12px; }
  .content li { margin-bottom: 4px; }
  .content code { background: #0d1117; border: 1px solid #1a2a3a; border-radius: 3px; padding: 1px 5px; font-family: monospace; font-size: 0.85em; color: #00c8f0; }
  .content pre { background: #0d1117; border: 1px solid #1a2a3a; border-radius: 6px; padding: 16px; overflow-x: auto; margin-bottom: 16px; }
  .content pre code { border: none; padding: 0; background: none; }
  .content strong { color: #b8ccd8; }
</style>
<div class="wrap">
  <a href="/blog/" class="back">&larr; Blog一覧</a>
  <div class="post-date">{formatDate(post.data.pubDate)}</div>
  <h1>{post.data.title}</h1>
  {post.data.tags && (
    <div class="tags">
      {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}
  <div class="content">
    <Content />
  </div>
  <nav class="footer-nav">
    <a href="/">Home</a>
    <a href="/blog/">Blog</a>
    <a href="/about.html">About</a>
    <a href="/contact.html">Contact</a>
  </nav>
</div>
</Base>
